# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/tmp
/output
/.playwright-cli

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc

# nwsl-model: logs and regenerable run artifacts
nwsl-model/logs/
nwsl-model/data/processed/models/
nwsl-model/data/processed/season_holdout/
nwsl-model/data/processed/tuning/

# nwsl-model: scraping debris and backups
nwsl-model/data/raw/*.bak_*
nwsl-model/data/raw/apify_*probe*.json
nwsl-model/data/raw/oddsportal_ajax_*
nwsl-model/data/raw/oddsportal_archive_*.json
nwsl-model/data/raw/oddsportal_asset_*.js
nwsl-model/data/raw/oddsportal_app_*.js
nwsl-model/data/raw/oddsportal_lscompressor_*.js
