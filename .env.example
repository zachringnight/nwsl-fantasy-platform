# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Supabase client config
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
# Optional legacy fallback if you still use anon keys in local setup
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server config
SUPABASE_SECRET_KEY=sb_secret_your_secret_key
# Optional fallback if you need the legacy service role key instead
SUPABASE_SERVICE_ROLE_KEY=

# Database
DATABASE_URL=postgresql://postgres:[YOUR-SUPABASE-DB-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Auth.js / NextAuth
AUTH_SECRET=replace-with-a-random-secret
